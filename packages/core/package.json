{
  "name": "lovely-alert",
  "version": "0.1.0",
  "description": "A beautiful, modern, accessible, themeable alert / modal / toast library with a fresh, ergonomic API.",
  "type": "module",
  "license": "MIT",
  "author": "Nguyễn Sơn Khánh <nguyenson.khanh4e@gmail.com>",
  "homepage": "https://github.com/xShiroeNguyenx/lovely-alert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xShiroeNguyenx/lovely-alert.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/xShiroeNguyenx/lovely-alert/issues",
  "keywords": [
    "alert",
    "modal",
    "dialog",
    "toast",
    "popup",
    "notification",
    "accessible",
    "dark-mode"
  ],
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/lovely-alert.umd.cjs",
  "module": "./dist/lovely-alert.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lovely-alert.js",
      "require": "./dist/lovely-alert.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "typescript": "5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.8"
  }
}
