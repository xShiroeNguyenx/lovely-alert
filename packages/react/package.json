{
  "name": "@lovely-alert/react",
  "version": "0.0.0",
  "description": "React bindings for lovely-alert (useAlert hook + re-exports).",
  "type": "module",
  "license": "MIT",
  "author": "Nguyễn Sơn Khánh <nguyenson.khanh4e@gmail.com>",
  "homepage": "https://github.com/xShiroeNguyenx/lovely-alert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xShiroeNguyenx/lovely-alert.git",
    "directory": "packages/react"
  },
  "bugs": "https://github.com/xShiroeNguyenx/lovely-alert/issues",
  "keywords": ["alert", "modal", "toast", "react", "lovely-alert"],
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.js",
