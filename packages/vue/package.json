{
  "name": "@lovely-alert/vue",
  "version": "0.1.0",
  "description": "Vue bindings for lovely-alert (plugin + composable + re-exports).",
  "type": "module",
  "license": "MIT",
  "author": "Nguyễn Sơn Khánh <nguyenson.khanh4e@gmail.com>",
  "homepage": "https://xshiroenguyenx.github.io/lovely-alert/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xShiroeNguyenx/lovely-alert.git",
    "directory": "packages/vue"
  },
  "bugs": "https://github.com/xShiroeNguyenx/lovely-alert/issues",
  "keywords": ["alert", "modal", "toast", "vue", "lovely-alert"],
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.js",
