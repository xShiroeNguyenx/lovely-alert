    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3"
  },
  "dependencies": {
    "lovely-alert": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "vue": "^3.5.13"
  }
